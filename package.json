    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
